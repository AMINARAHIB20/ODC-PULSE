# Browser-safe Supabase settings (Dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Server-only admin credential. Never use a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Modern alternative to SUPABASE_SERVICE_ROLE_KEY. Configure only one admin key.
# SUPABASE_SECRET_KEY=sb_secret_your_key

# Server-only n8n production webhook and Header Auth secret
N8N_IMPACT_WEBHOOK_URL=https://your-n8n-domain.example/webhook/odc-employability
N8N_WEBHOOK_SECRET=replace_with_a_long_random_secret
